{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mystia Steward Companion",
  "version": "0.1.0",
  "identifier": "com.tyukki.mystia-steward.companion",
  "build": {
    "beforeDevCommand": "corepack pnpm dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173/",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "夜雀掌柜",
        "url": "/",
        "width": 1040,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
